# ============================================================
# CONFIGURATION FASTAPI SERVICE — COPIER EN .env ET REMPLIR
# ============================================================

# Serveur
PORT=8000
HOST=0.0.0.0

# Dossier de stockage des fichiers médias
UPLOAD_DIR=./uploads

# Taille maximale d'upload (en Mo)
MAX_UPLOAD_MB=100

# Clé secrète JWT (doit correspondre à celle d'Express)
JWT_SECRET=CHANGER_CETTE_VALEUR_PAR_UNE_CLE_SECRETE_LONGUE

# Dimensions maximales des images (redimensionnement automatique)
MAX_IMAGE_WIDTH=4096
MAX_IMAGE_HEIGHT=4096

# Qualité de compression JPEG (1-95)
JPEG_QUALITY=85

# Générer une miniature de cette taille
MINIATURE_TAILLE=400

# Environnement
ENVIRONMENT=development
