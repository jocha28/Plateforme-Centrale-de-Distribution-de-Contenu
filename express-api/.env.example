# ============================================================
# CONFIGURATION EXPRESS API — COPIER EN .env ET REMPLIR
# ============================================================

# Serveur
PORT=3000
NODE_ENV=development

# Sécurité JWT
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGER_CETTE_VALEUR_PAR_UNE_CLE_SECRETE_LONGUE
JWT_EXPIRES_IN=7d

# Compte administrateur (créé au démarrage si inexistant)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGER_CE_MOT_DE_PASSE

# Base de données SQLite
DB_PATH=./src/db/plateforme.db

# Service FastAPI (médias)
FASTAPI_URL=http://localhost:8000

# Limite d'upload (en mégaoctets)
MAX_UPLOAD_SIZE_MB=50

# CORS — domaines autorisés (séparés par des virgules)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Logs
LOG_LEVEL=info
